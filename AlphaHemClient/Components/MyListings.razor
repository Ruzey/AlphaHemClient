
@* Author: Conny *@

<div class="container py-2">
    <h4>Mina objekt</h4>

    @if (listingsVM == null)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 80vh;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Laddar...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover table-mylistings">
                <thead>
                    <tr>
                        <th>Adress</th>
                        <th>Kommun</th>
                        <th>Kategori</th>
                        <th>Pris</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var listing in listingsVM)
                    {
                        <tr>
                            <td>@listing.Address</td>
                            <td>@listing.Municipality</td>
                            <td>@listing.Category</td>
                            <td>@listing.Price.ToString("C", priceFormat)</td>
                            <td>
                                <a href="/editListing/@listing.Id"><i class="icon bi bi-pencil-square fs-5"></i></a> | <a href=""><i class="icon bi bi-trash-fill fs-5"></i></a> | <a href="/listings/@listing.Id"><i class="icon bi bi-link fs-5 font-weight-bold"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

