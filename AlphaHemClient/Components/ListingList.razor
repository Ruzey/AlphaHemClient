@* Author: Christoffer *@

@if (Listings is null || !Listings.Any())
{
    <p>Det finns inga bostäder till salu</p>
}
else
{
<section id="real-estate" class="real-estate section">

    <div class="container">

        <div class="row gy-4">
            @foreach (var listing in Listings)
            {
                            <div class="col-xl-4 col-md-6" data-aos="fade-up" data-aos-delay="600">
                    <NavLink class="card" href="@($"/listings/{listing.Id}")"> @* Author: Niklas *@
              
              <div class="card-body">
                            <span class="sale-rent">Till salu | @listing.Price kr</span>
                            <h3><a href="property-single.html" class="stretched-link">@listing.Address</a></h3>
                <div class="card-content d-flex flex-column justify-content-center text-center">
                  <div class="row propery-info">
                                    <div class="col">Kommun</div>
                                    <div class="col">Bostadsform</div>
                                    <div class="col">Mäklare</div>
                  </div>
                  <div class="row">
                                    <div class="col">@listing.Municipality</div>
                                    <div class="col">@listing.Category</div>
                                    <div class="col">@listing.RealtorFullName</div>
                  </div>
                </div>
              </div>
            </NavLink>
          </div><!-- End Property Item -->
          }
        </div>

      </div>

    </section><!-- /Real Estate Section -->
    }