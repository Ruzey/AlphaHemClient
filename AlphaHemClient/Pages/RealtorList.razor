@page "/realtors"
@using AlphaHemAPI.Data.DTO
@inject HttpClient Http

<h3>Mäklare</h3>

@if (realtors == null)
{
    <p>Laddar...</p>
}
else
{
    <ul class="list-group">
        @foreach (var realtor in realtors)
        {
            <li class="list-group-item d-flex align-items-center">
                <img src="@realtor.ProfilePicture" alt="No Img" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover; margin-right: 15px;" />
                <div>
                    <strong>@realtor.FullName</strong>
                    <br />
                    <span>@realtor.PhoneNumber</span>
					<br />
					<span>@realtor.Email</span>
					<br />
					<span>@realtor.Agency</span>
                </div>
            </li>
        }
    </ul>
}

@code {
    private List<RealtorDto> realtors;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetFromJsonAsync<List<RealtorDto>>("https://localhost:7109/api/Realtor");
        if (response != null)
        {
            realtors = response;
        }
        else
        {
            realtors = new List<RealtorDto>();
        }
    }
}
