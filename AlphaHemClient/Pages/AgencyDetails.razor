@page "/agency/{id:int}"
@using AlphaHemClient.Components
@using Microsoft.AspNetCore.Components.Authorization
@*Author: Mattias*@
@*Co-Author: ALL*@
@if (agency == null)
{
    <p><em>Laddar byråinformation...</em></p>
}
else
{
    <section class="about section">
        <div class="container">

            <div class="row gy-4">

                <div class="col-lg-6 about-images" data-aos="fade-up" data-aos-delay="200">
                    <img src="@(!string.IsNullOrEmpty(agency.Logo) ? agency.Logo : "https://i.imgur.com/g3aix21.png")" class="img-fluid" alt="@agency.Name">
                </div>

                <div class="col-lg-6 content" data-aos="fade-up" data-aos-delay="100">
                    <p class="who-we-are">Våran byrå</p>
                    <h3>@agency?.Name</h3>
                    <p class="fst-italic">@agency?.Presentation</p>

                        <h5 class="mt-4">Våra mäklare</h5>
                        <ul>
                            @foreach (var realtor in agency.Realtors)
                            {
                                @if(realtor.EmailConfirmed)
                                {
                                <li class="list-group-item d-flex align-items-center">
                                    <RealtorImage ImageUrl="@realtor.ProfilePicture"
                                            class="rounded-circle"
                                            style="width: 50px; height: 50px; object-fit: cover; margin-right: 15px;" />
                                    <div>
                                        <strong>@realtor.FirstName @realtor.LastName</strong>
                                        <br />
                                        <span>@realtor.PhoneNumber</span>
                                        <br />
                                        <span>@realtor.Email</span>
                                        <br />
                                    <a href="/realtor/@realtor.Id" style="color: #9B2EC9">Se profil</a>
                                    </div>
                                </li>
                                }
                            }
                        </ul>


                        @if(sameAgency)
                        {
                            <AuthorizeView Roles="RealtorAdmin">
                                <Authorized>
								@if (agency.Realtors.Any(r => !r.EmailConfirmed))
                                {
                                  <h5 class="mt-4">Väntar på konto confirmed</h5>
                                    <ul>
                                        @foreach (var realtor in agency.Realtors)
                                        {
                                            @if (!realtor.EmailConfirmed)
                                            {
                                                <li class="list-group-item d-flex align-items-center">
                                                    <RealtorImage ImageUrl="@realtor.ProfilePicture"
                                                                  class="rounded-circle"
                                                                  style="width: 50px; height: 50px; object-fit: cover; margin-right: 15px;" />
                                                    <div>
                                                        <strong>@realtor.FirstName @realtor.LastName</strong>
                                                        <br />
                                                        <span>@realtor.PhoneNumber</span>
                                                        <br />
                                                        <span>@realtor.Email</span>
                                                        <br />
                                                        <a href="/realtor/@realtor.Id" style="color: #9B2EC9">Se profil</a>
													    <br />
                                                        <button class="btn btn-primary" @onclick="() => ApproveRealtor(realtor.Id)">Godkänn</button>
                                                        <button class="btn btn-danger" @onclick="() => DeclineRealtor(realtor.Id)">Avböj</button>
                                                    </div>
                                                </li>
                                            }
                                        }
                                    </ul>
                                }
                                </Authorized>
                            </AuthorizeView>
                        }

                </div>


            </div>

        </div>
    </section>
}