@page "/listings/{id:int}"
@using AlphaHemAPI.Data.DTO
@using AlphaHemClient.Components
@using AlphaHemClient.HelperClasses
@* Author: Niklas 
   Co-author: Smilla
*@
@if (listing == null)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 80vh;">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Laddar...</span>
        </div>
    </div>
}
else
{
    <div class="container py-5">
        <div class="card shadow-sm p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <h1 class="fw-bold">@listing.Address<EditPen ListingId="@listing.Id" class="ms-3"/></h1>
                    <h5 class="text-muted">@listing.Category - @listing.MunicipalityName</h5>
                    <h2 class="text-primary mt-3" style="color: #9B2EC9 !important">@listing.Price.ToPriceString()</h2>

                    <ul class="list-group list-group-flush my-4">
                        <li class="list-group-item"><strong>Antal rum:</strong> @listing.Rooms</li>
                        <li class="list-group-item"><strong>Byggår:</strong> @listing.YearBuilt</li>
                        <li class="list-group-item"><strong>Boarea:</strong> @listing.LivingArea m²</li>
                        <li class="list-group-item"><strong>Biarea:</strong> @listing.SecondaryArea m²</li>
                        <li class="list-group-item"><strong>Tomtarea:</strong> @listing.LotArea m²</li>
                        <li class="list-group-item"><strong>Månadsavgift:</strong> @listing.MonthlyFee.ToPriceString()</li>
                        <li class="list-group-item"><strong>Årlig driftkostnad:</strong> @listing.YearlyOperatingCost.ToPriceString()</li>
                    </ul>

                    <h4 class="mt-4">Kontaktinformation</h4>
                    <p><i class="bi bi-person-fill"></i> <strong>@listing.Realtor.FullName</strong></p>
                    <p><i class="bi bi-telephone-fill"></i> @listing.Realtor.PhoneNumber</p>
                    <p><i class="bi bi-envelope-fill"></i> @listing.Realtor.Email</p>
                    <p><i class="bi bi-building"></i> @listing.Realtor.AgencyName</p>
                    <a href="/realtor/@listing.Realtor.Id" style="color: #9B2EC9">Se profil</a>
                </div>

                <div class="col-md-6">
                    <div class="mt-4">
                        <h4>Beskrivning</h4>
                        <p>@listing.Description</p>
                    </div>

                    @if (listing.Images != null && listing.Images.Any())
                    {
                        <div class="mt-4">
                            <h5>Bilder</h5>
                            @foreach (var img in listing.Images)
                            {
                                <img src="@img" class="img-fluid rounded mb-3" alt="Bostadsbild" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

